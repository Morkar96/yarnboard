# Copy this file to .env for local development (python-dotenv loads it
# automatically). In production (Render) these are set as real environment
# variables in the dashboard instead of a file.

# Used to sign session cookies. Generate a real random value for prod, e.g.
# `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=dev-secret-key-change-me

# Neon Postgres connection string, e.g.
# postgresql://user:password@ep-xxxx.neon.tech/yarnboard?sslmode=require
# Leave unset locally to fall back to a SQLite file (yarnboard.db).
DATABASE_URL=

# Comma-separated list of origins allowed to make credentialed requests to
# this API. Locally this is the Vite dev server; in prod it's the deployed
# frontend's Render URL.
CORS_ORIGINS=http://localhost:5173

# "development" or "production" -- controls session cookie security
# settings (see app/config.py).
FLASK_ENV=development

# Resend (https://resend.com) API key, used to email users when a pattern
# they have checklist progress on gets edited (see app/email.py). Leave
# unset locally -- sends are logged instead of delivered when it's absent.
RESEND_API_KEY=
# Must be on a domain verified in your Resend account.
RESEND_FROM_EMAIL=Yarnboard <notifications@yourdomain.com>

# The deployed frontend's URL, used to build absolute links in emails
# (unlike the frontend's own fetch calls, email clients can't resolve
# relative paths).
PUBLIC_APP_URL=http://localhost:5173
