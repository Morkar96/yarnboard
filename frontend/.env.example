# Copy to .env.local for local development.
# Base URL of the Flask API (see backend/.env.example). Only needed
# locally, where Vite (5173) and Flask (5001) run as separate dev
# servers -- in production, Flask serves this build itself from the same
# origin, so VITE_API_BASE_URL is deliberately left unset there and the
# app falls back to relative "/api/..." requests (see src/api/client.ts).
VITE_API_BASE_URL=http://localhost:5001
